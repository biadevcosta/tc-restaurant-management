          "name": "Success",
          "item": [
            {
              "name": "Create Restaurant Owner",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "url": {
                  "raw": "{{baseUrl}}/restaurant-owners",
                  "host": ["{{baseUrl}}"],
                  "path": ["restaurant-owners"]
                },
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"João Silva\",\n  \"email\": \"joao@restaurante.com\",\n  \"login\": \"joaosilva\",\n  \"password\": \"senha123\",\n  \"address\": {\n    \"street\": \"Rua das Flores\",\n    \"number\": \"123\",\n    \"city\": \"São Paulo\",\n    \"state\": \"SP\",\n    \"zipCode\": \"01310-100\"\n  }\n}"
                }
              }
            },
            {
              "name": "Get Restaurant Owner by ID",
              "request": {
                "method": "GET",
                "url": {
                  "raw": "{{baseUrl}}/restaurant-owners/1",
                  "host": ["{{baseUrl}}"],
                  "path": ["restaurant-owners", "1"]
                }
              }
            },
            {
              "name": "Search Restaurant Owner by Name",
              "request": {
                "method": "GET",
                "url": {
                  "raw": "{{baseUrl}}/restaurant-owners?name=joão",
                  "host": ["{{baseUrl}}"],
                  "path": ["restaurant-owners"],
                  "query": [{ "key": "name", "value": "joão" }]
                }
              }
            },
            {
              "name": "Delete Restaurant Owner",
